## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml

# Visual Studio cache/options directory
.vs/

# Build results
bin/
obj/
*.dll
*.pdb

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Local History for Visual Studio
.localhistory/

# Backup & temp files
*.tmp
*.bak
*~
*.swp
*.swo

# Node
node_modules/
npm-debug.log

# .NET
.nuget/packages/
*.csproj.user

# VS Code
.vscode/

# Environment files
.env
.env.local
