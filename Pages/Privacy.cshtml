@page
@model PrivacyModel
@{
    ViewData["Title"] = "Employees";
}

<style>
    .employees-container {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        margin-bottom: 30px;
    }

    .employees-title {
        color: #0078d4;
        font-weight: 600;
        margin-bottom: 25px;
        font-size: 2rem;
    }

    .table-fluent {
        width: 100%;
        border-collapse: collapse;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
        overflow: hidden;
    }

    .table-fluent thead {
        background: linear-gradient(90deg, #0078d4 0%, #0078d4 100%);
        color: white;
    }

    .table-fluent th {
        padding: 16px 12px;
        text-align: left;
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
    }

    .table-fluent tbody tr {
        border-bottom: 1px solid #e0e0e0;
        transition: all 0.3s ease;
    }

    .table-fluent tbody tr:hover {
        background-color: #f0f7ff;
        box-shadow: inset 0 2px 8px rgba(0, 120, 212, 0.1);
    }

    .table-fluent td {
        padding: 14px 12px;
        font-size: 0.95rem;
        color: #333;
    }

    .table-fluent tbody tr:last-child {
        border-bottom: none;
    }

    .badge-dept {
        display: inline-block;
        background: linear-gradient(135deg, #0078d4, #50e3c2);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .job-title {
        color: #0078d4;
        font-weight: 500;
    }

    .hire-date {
        color: #666;
        font-size: 0.9rem;
    }

    .no-employees {
        text-align: center;
        padding: 40px;
        color: #999;
    }
</style>

<div class="employees-container">
    <h1 class="employees-title">
        <i class="fas fa-users"></i> Employees
    </h1>

    @if (Model.Employees != null && Model.Employees.Count > 0)
    {
        <table class="table-fluent">
            <thead>
                <tr>
                    <th>
                        <i class="fas fa-user"></i> First Name
                    </th>
                    <th>
                        <i class="fas fa-user"></i> Last Name
                    </th>
                    <th>
                        <i class="fas fa-calendar"></i> Hiring Date
                    </th>
                    <th>
                        <i class="fas fa-building"></i> Department
                    </th>
                    <th>
                        <i class="fas fa-briefcase"></i> Job Title
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model.Employees)
                {
                    <tr>
                        <td>@employee.FirstName</td>
                        <td>@employee.LastName</td>
                        <td class="hire-date">@(DateTime.Parse(employee.HiringDate).ToString("MMM dd, yyyy"))</td>
                        <td>
                            <span class="badge-dept">@employee.Department</span>
                        </td>
                        <td class="job-title">@employee.JobTitle</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="no-employees">
            <p><i class="fas fa-inbox"></i> No employees found.</p>
        </div>
    }
</div>
