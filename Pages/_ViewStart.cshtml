@*
    _ViewStart.cshtml
    
    This file is executed before any view is rendered in the Pages directory.
    It's used to set common properties that apply to all views in the directory.
    
    In this case, we set the Layout property to "_Layout" which means:
    - All pages will use the "_Layout.cshtml" master page/layout template
    - The layout provides consistent branding, navigation, and styling across all pages
*@

@{
    Layout = "_Layout";
}
